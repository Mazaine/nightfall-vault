# Copy to .env.production, restrict it to the service account, and replace every CHANGE_ME value.
COMPOSE_PROJECT_NAME=nightfall-vault-production
PRODUCTION_ENV_FILE=.env.production
HTTP_PORT=8080
CORE_SUBNET=172.30.0.0/24
REVERSE_PROXY_IP=172.30.0.10
NIGHTFALL_IMAGE_TAG=local

POSTGRES_DB=nightfall_vault
POSTGRES_USER=nightfall_app
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
DATABASE_URL=postgresql+psycopg://nightfall_app:CHANGE_ME_DATABASE_PASSWORD@postgres:5432/nightfall_vault
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0
SECRET_KEY=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS

BACKEND_CORS_ORIGINS=["https://vault.example.invalid"]
TRUSTED_PROXY_CIDRS=["172.30.0.10/32"]
APP_FRONTEND_URL=https://vault.example.invalid
APP_BACKEND_URL=https://vault.example.invalid
FRONTEND_BASE_URL=https://vault.example.invalid
MEDIA_ROOT=/data/media
MEDIA_URL_PREFIX=/media
STORAGE_BACKEND=local
ENVIRONMENT=production
LOG_LEVEL=INFO
LOG_FORMAT=json
RATE_LIMIT_BACKEND=redis
AUCTION_SCHEDULER_MODE=external
AUCTION_SCHEDULER_INTERVAL_SECONDS=10
AUCTION_SCHEDULER_HEARTBEAT_TTL_SECONDS=30
REALTIME_STREAM_MAX_LENGTH=5000
DEVELOPMENT_ADMIN_SEED_ENABLED=false
EMAIL_DELIVERY_ENABLED=false
CAPTCHA_ENABLED=false

MEDIA_VOLUME_NAME=nightfall_vault_media_prod
DATABASE_VOLUME_NAME=nightfall_vault_postgres_prod
REDIS_VOLUME_NAME=nightfall_vault_redis_prod
BACKUP_DIRECTORY=/srv/nightfall-vault/backups
BACKUP_RETENTION_DAYS=14
OFFSITE_BACKUP_MODE=disabled
OFFSITE_BACKUP_TARGET=
